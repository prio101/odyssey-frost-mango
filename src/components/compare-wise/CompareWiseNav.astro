---
import Container from '../core/Container.astro';

const { current } = Astro.props;

const links = [
	{ title: 'Home', slug: '/compare-wise' },
	{ title: 'Pricing', slug: '/compare-wise/pricing' },
	{ title: 'Q&A', slug: '/compare-wise/qa' },
	{ title: 'Privacy', slug: '/compare-wise/privacy' },
];
---

<Container>
	<nav class="bannerbird-nav">
		<a class="bannerbird-nav__logo" href="/compare-wise">Compare Wise</a>
		<ul class="bannerbird-nav__list">
			{links.map((link) => (
				<li>
					<a
						class={`bannerbird-nav__link ${current === link.slug ? 'bannerbird-nav__link--active' : ''}`}
						href={link.slug}
					>
						{link.title}
					</a>
				</li>
			))}
		</ul>
	</nav>
</Container>

<style>
	.bannerbird-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		margin-bottom: 1rem;
		border-bottom: 1px solid var(--theme-divider);
	}
	.bannerbird-nav__logo {
		font-family: var(--theme-font-family-sans);
		font-weight: 700;
		font-size: 1.1rem;
		text-decoration: none;
		color: var(--theme-on-surface);
	}
	.bannerbird-nav__list {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 1.5rem;
	}
	.bannerbird-nav__link {
		text-decoration: none;
		color: var(--theme-on-surface);
		font-size: 0.9rem;
		opacity: 0.7;
		transition: opacity var(--theme-transition);
	}
	.bannerbird-nav__link:hover {
		opacity: 1;
	}
	.bannerbird-nav__link--active {
		opacity: 1;
		font-weight: 600;
	}
	@media (max-width: 768px) {
		.bannerbird-nav {
			flex-direction: column;
			gap: 0.75rem;
		}
		.bannerbird-nav__list {
			gap: 1rem;
		}
	}
</style>
